@using API.Client.Abstraction
@using Models.Common
@inject ICampaignClient CampaignClient

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="glow">Campaigns</h2>
        <a href="/campaigns/new" class="btn-secondary disabled">
            New Campaign
        </a>
    </div>

    @if (_campaigns == null)
    {
        <div class="text-center py-5">
            <p class="mt-2 glow">Loading campaigns...</p>
        </div>
    }
    else if (!_campaigns.Any())
    {
        <div class="card py-5 text-center">
            <p class="mb-0">No campaigns found. Start by creating one!</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var campaign in _campaigns)
            {
                <div class="col">
                    <div class="card h-100 campaign-card">
                        <div class="card-body">
                            <h3 class="card-title glow">@campaign.EntityId</h3>
                            <p class="card-text">@GetDescription(campaign)</p>
                        </div>
                        <div class="card-footer pt-0 pb-3">
                            <a href="/campaigns/@campaign.Id" class="btn-primary d-block text-center" style="text-decoration: none;">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private IEnumerable<JsonResource>? _campaigns;

    protected override async Task OnInitializedAsync()
    {
        _campaigns = await CampaignClient.GetAllAsync();
    }

    private string GetDescription(JsonResource resource)
    {
        if (resource.Data.TryGetProperty("description", out var prop))
        {
            return prop.GetString() ?? "No description available.";
        }
        return "No description available.";
    }
}
