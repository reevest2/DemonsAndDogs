@using API.Client.Abstraction
@using Models.Common
@using Models.GameSystems
@inject ICharacterClient CharacterClient
@inject IGameSystemClient GameSystemClient

<div class="container py-4">
    @if (_character == null)
    {
        <div class="text-center py-5">
            <p class="mt-2 glow">Loading character...</p>
        </div>
    }
    else
    {
        <nav aria-label="breadcrumb" class="mb-4">
            <a href="/characters">Characters</a> / <span>@_character.EntityId</span>
        </nav>

        <div class="row">
            <div class="col-lg-4">
                <div class="card mb-4 text-center">
                    <div class="card-body p-4">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 120px; height: 120px; border: 3px solid var(--accent-primary); color: var(--accent-primary);">
                            <span style="font-size: 48px;">👤</span>
                        </div>
                        <h2 class="glow">@_character.EntityId</h2>
                        <p>@_character.RulesetId</p>
                        <div class="divider"></div>
                        <div class="text-left small">
                            <div class="d-flex justify-content-between mb-2">
                                <span>System:</span>
                                <strong>@_character.GameId</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Owner:</span>
                                <strong>@_character.OwnerId</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                @if (_schema == null)
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <p class="glow mb-0">Unrolling parchment...</p>
                        </div>
                    </div>
                }
                else
                {
                    <CharacterSheetComponent Schema="_schema" />
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string CharacterId { get; set; } = "";

    private JsonResource? _character;
    private CharacterSheetSchema? _schema;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(CharacterId)) return;

        _character = await CharacterClient.GetByIdAsync(CharacterId);
        
        if (_character != null && !string.IsNullOrEmpty(_character.GameId))
        {
            try 
            {
                _schema = await GameSystemClient.GetSchemaAsync(_character.GameId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading schema for system {_character.GameId}: {ex.Message}");
            }
        }
    }
}
