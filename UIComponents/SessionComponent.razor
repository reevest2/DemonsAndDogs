@using API.Client.Abstraction
@using Mediator.Mediator.Contracts.Session
@using Models.Session
@using Models.GameSystems
@inject ISessionClient SessionClient

<div class="container-fluid py-4">
    @if (_sessionState == null)
    {
        <div class="text-center py-5">
            <p class="mt-2 glow">Connecting to session...</p>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-3">
                <CharacterSheetComponent Schema="_sessionState.CharacterSheetSchema" />
            </div>
            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-body text-center">
                        <h1 class="glow mb-3">@_sessionState.CharacterName</h1>
                        <div class="d-flex justify-content-center gap-3">
                            <button class="btn-primary" @onclick="RollSkillCheck" style="font-size: 1.25rem;">
                                ⚡ Roll Stealth
                            </button>
                            <button class="btn-primary" @onclick="MakeAttack" style="background-color: var(--accent-secondary); font-size: 1.25rem;">
                                ⚔ Attack
                            </button>
                        </div>
                    </div>
                </div>
                
                <ActionLogComponent Events="_sessionState.EventLog" />
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card-header glow">DM Narration</div>
                    <div class="card-body">
                        <p class="opacity-50 italic">Narration will appear here in Phase 4.</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? SessionId { get; set; }
    private SessionState? _sessionState;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(SessionId))
        {
            try 
            {
                _sessionState = await SessionClient.GetSessionAsync(SessionId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading session: {ex.Message}");
            }
        }
    }

    private async Task RollSkillCheck()
    {
        if (_sessionState == null) return;
        
        try
        {
            var context = new SkillCheckContext(_sessionState.SessionId, "stealth", 3, 2, 15);
            var request = new PerformActionRequest(_sessionState.SessionId, ActionType.SkillCheck, SkillCheckContext: context);
            var result = await SessionClient.PerformActionAsync(request);
            
            UpdateLocalLog(result);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error performing skill check: {ex.Message}");
        }
    }

    private async Task MakeAttack()
    {
        if (_sessionState == null) return;
        
        try
        {
            var context = new AttackContext("longsword", 5, 14);
            var request = new PerformActionRequest(_sessionState.SessionId, ActionType.Attack, AttackContext: context);
            var result = await SessionClient.PerformActionAsync(request);
            
            UpdateLocalLog(result);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error performing attack: {ex.Message}");
        }
    }

    private void UpdateLocalLog(SessionEvent result)
    {
        if (_sessionState == null) return;
        var newLog = new List<SessionEvent>(_sessionState.EventLog) { result };
        _sessionState = _sessionState with { EventLog = newLog };
    }
}
