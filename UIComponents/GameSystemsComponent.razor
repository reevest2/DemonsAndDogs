@using API.Client.Abstraction
@using Models.GameSystems
@inject IGameSystemClient GameSystemClient

<div class="container py-4">
    <div class="mb-4">
        <h2 class="glow">Game Systems</h2>
        <p>Available rulebooks and game systems supported by Demons & Dogs.</p>
    </div>

    @if (_systems == null)
    {
        <div class="text-center py-5">
            <p class="mt-2 glow">Loading game systems...</p>
        </div>
    }
    else if (!_systems.Any())
    {
        <div class="card py-5 text-center">
            <p class="mb-0">No game systems found in the registry.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var system in _systems)
            {
                <div class="col">
                    <div class="card h-100 system-card">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="rounded p-2 mr-3" style="background-color: var(--accent-secondary); color: white;">
                                    <span>📜</span>
                                </div>
                                <h4 class="card-title glow mb-0">@system.DisplayName</h4>
                            </div>
                            <p class="card-text small">System ID: <code>@system.SystemId</code></p>
                        </div>
                        <div class="card-footer pt-0 pb-3">
                            <button class="btn-secondary d-block text-center w-100 disabled" style="font-size: 0.8rem;">
                                System Specs
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private IEnumerable<GameSystemDescriptor>? _systems;

    protected override async Task OnInitializedAsync()
    {
        _systems = await GameSystemClient.GetAllAsync();
    }
}
