@using API.Client.Abstraction
@using Models.Common
@inject ICampaignClient CampaignClient
@inject IApiClient ApiClient

<div class="container py-4">
    @if (_campaign == null)
    {
        <div class="text-center py-5">
            <p class="mt-2 glow">Loading campaign details...</p>
        </div>
    }
    else
    {
        <nav aria-label="breadcrumb" class="mb-4">
            <a href="/campaigns">Campaigns</a> / <span>@_campaign.EntityId</span>
        </nav>

        <div class="card mb-4">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <div class="col">
                        <h1 class="glow mb-1">@_campaign.EntityId</h1>
                        <p class="lead mb-0">@GetDescription(_campaign)</p>
                    </div>
                    <div class="col-auto">
                        <a href="/session/new?campaignId=@CampaignId" class="btn-primary" style="text-decoration: none; font-size: 1.25rem;">
                            Start Session
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <h3 class="mb-3 glow">Characters</h3>
        @if (_characters == null)
        {
            <div class="text-center py-4">
                <p class="glow">Searching for heroes...</p>
            </div>
        }
        else if (!_characters.Any())
        {
            <div class="card text-center py-4">
                <p class="mb-0 italic">No characters assigned to this campaign yet.</p>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3">
                @foreach (var character in _characters)
                {
                    <div class="col">
                        <div class="card h-100 text-center">
                            <div class="card-body">
                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px; border: 2px solid var(--accent-primary); color: var(--accent-primary);">
                                    <span style="font-size: 24px;">👤</span>
                                </div>
                                <h4 class="card-title mb-1 glow">@character.EntityId</h4>
                                <p class="small mb-3">@character.RulesetId</p>
                                <a href="/characters/@character.Id" class="btn-secondary btn-sm" style="text-decoration: none;">View Sheet</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string CampaignId { get; set; } = "";

    private JsonResource? _campaign;
    private IEnumerable<JsonResource>? _characters;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(CampaignId)) return;

        _campaign = await CampaignClient.GetByIdAsync(CampaignId);
        
        // Fetch characters for this campaign
        try 
        {
            _characters = await ApiClient.Get<IEnumerable<JsonResource>>($"api/JsonResource/query?resourceKind=character&campaignId={CampaignId}", default);
        }
        catch 
        {
            _characters = Array.Empty<JsonResource>();
        }
    }

    private string GetDescription(JsonResource resource)
    {
        if (resource.Data.TryGetProperty("description", out var prop))
        {
            return prop.GetString() ?? "No description available.";
        }
        return "No description available.";
    }
}
