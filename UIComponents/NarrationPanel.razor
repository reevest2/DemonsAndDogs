@using System.Text
@using System.IO
@using API.Client
@inject IApiClient ApiClient

<div class="narration-panel card @(ThemeClass) mt-4 mb-4 glow-@(Theme)">
    <div class="card-header border-bottom border-secondary">
        <h3 class="heading-@(Theme) m-0">Mordecai's Narration</h3>
    </div>
    <div class="card-body">
        <p class="narration-text">@DisplayedText<span class="cursor">|</span></p>
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-container">
                <strong>An error occurred in the shadows:</strong>
                <p>@ErrorMessage</p>
                @if (!string.IsNullOrEmpty(ErrorStackTrace))
                {
                    <pre class="error-stack">@ErrorStackTrace</pre>
                }
            </div>
        }
    </div>
</div>

<style>
    .narration-text {
        font-family: var(--font-body);
        font-style: italic;
        line-height: 1.6;
        min-height: 4em;
        font-size: 1.1rem;
        color: var(--text-on-card);
    }
    .cursor {
        font-weight: bold;
        animation: blink 1s step-end infinite;
        color: var(--accent-primary);
        margin-left: 2px;
    }
    @@keyframes blink {
        from, to { opacity: 0; }
        50% { opacity: 1; }
    }
    .error-container {
        color: #ff4d4d;
        border: 1px solid #ff4d4d;
        background: rgba(255, 77, 77, 0.1);
        padding: 1rem;
        margin-top: 1rem;
        border-radius: 4px;
        font-family: monospace;
    }
    .error-stack {
        font-size: 0.8rem;
        white-space: pre-wrap;
        margin-top: 0.5rem;
        border-top: 1px solid rgba(255, 77, 77, 0.3);
        padding-top: 0.5rem;
    }
</style>

@code {
    [Parameter] public string Theme { get; set; } = "fantasy";

    private string DisplayedText { get; set; } = "";
    private string? ErrorMessage { get; set; }
    private string? ErrorStackTrace { get; set; }
    private string ThemeClass => Theme == "steampunk" ? "card-steampunk" : "card-fantasy";

    public async Task StartNarration(string sessionId)
    {
        DisplayedText = "";
        ErrorMessage = null;
        ErrorStackTrace = null;
        StateHasChanged();

        try
        {
            var url = $"api/narration/stream/{sessionId}";
            await foreach (var token in ApiClient.GetStream(url))
            {
                if (token.StartsWith("[ERROR]"))
                {
                    ErrorMessage = token.Replace("[ERROR]", "").Trim();
                    StateHasChanged();
                    break;
                }

                foreach (var ch in token)
                {
                    DisplayedText += ch;
                    StateHasChanged();
                    await Task.Delay(15);
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            ErrorStackTrace = ex.StackTrace;
            StateHasChanged();
            throw;
        }
    }
}