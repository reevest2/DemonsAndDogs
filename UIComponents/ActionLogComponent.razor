@using Models.Session
@using Models.GameSystems

<div class="card shadow-sm h-100">
    <div class="card-header bg-primary text-white">Action Log</div>
    <div class="card-body overflow-auto" style="max-height: 500px;">
        @if (Events != null && Events.Count > 0)
        {
            @foreach (var evt in Events.OrderByDescending(e => e.Timestamp))
            {
                <div class="alert @GetAlertClass(evt) mb-2 border-0 shadow-sm p-2">
                    <div class="d-flex justify-content-between">
                        <span class="badge badge-dark mb-1">@evt.EventType</span>
                        <small class="text-muted">@evt.Timestamp.ToString("HH:mm:ss")</small>
                    </div>
                    <div>@evt.Description</div>
                    
                    @if (evt.CheckResult != null)
                    {
                        <div class="mt-1 small">
                            <span class="mr-2">Roll: @evt.CheckResult.RollValue</span>
                            <span class="font-weight-bold">Total: @evt.CheckResult.TotalResult</span>
                        </div>
                    }
                    else if (evt.AttackResult != null)
                    {
                        <div class="mt-1 small">
                            <span class="mr-2">Roll: @evt.AttackResult.AttackRoll</span>
                            <span class="font-weight-bold">Total: @evt.AttackResult.TotalAttackResult</span>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="text-center p-5 text-muted">
                <i class="oi oi-list"></i>
                <p class="mt-2">No actions performed yet.</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<SessionEvent>? Events { get; set; }

    private string GetAlertClass(SessionEvent evt)
    {
        if (evt.CheckResult != null)
        {
            return evt.CheckResult.IsSuccess ? "alert-success" : "alert-warning";
        }
        if (evt.AttackResult != null)
        {
            return evt.AttackResult.IsHit ? "alert-danger" : "alert-secondary";
        }
        return "alert-light";
    }
}
