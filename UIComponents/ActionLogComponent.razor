@using Models.Session
@using Models.GameSystems

<div class="card @(ThemeClass) h-100">
    <div class="card-header border-bottom border-secondary">
        <h3 class="heading-@(Theme) m-0">Action Log</h3>
    </div>
    <div class="card-body overflow-auto" style="max-height: 500px;">
        @if (Events != null && Events.Count > 0)
        {
            @foreach (var evt in Events.OrderByDescending(e => e.Timestamp))
            {
                <div class="mb-3 p-3" style="border-left: 4px solid @GetEventColor(evt); background-color: rgba(0,0,0,0.05); border-radius: 0 8px 8px 0;">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="badge" style="background-color: @GetEventColor(evt); color: white;">@evt.EventType</span>
                        <small class="opacity-75">@evt.Timestamp.ToString("HH:mm:ss")</small>
                    </div>
                    <div class="mb-2" style="font-family: var(--font-body); color: var(--text-on-card);">@evt.Description</div>

                    @if (evt.CheckResult != null)
                    {
                        <div class="p-1 px-2 mt-1 rounded small" style="font-family: var(--font-mono); background: rgba(0,0,0,0.1); display: inline-block; color: var(--accent-primary);">
                            <span class="me-3">ROLL: @evt.CheckResult.RollValue</span>
                            <span class="fw-bold">TOTAL: @evt.CheckResult.TotalResult</span>
                        </div>
                    }
                    else if (evt.AttackResult != null)
                    {
                        <div class="p-1 px-2 mt-1 rounded small" style="font-family: var(--font-mono); background: rgba(0,0,0,0.1); display: inline-block; color: var(--accent-primary);">
                            <span class="me-3">ROLL: @evt.AttackResult.AttackRoll</span>
                            <span class="fw-bold">TOTAL: @evt.AttackResult.TotalAttackResult</span>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="text-center p-5 opacity-50">
                <span style="font-size: 3rem;">📜</span>
                <p class="mt-2">No actions performed yet.</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<SessionEvent>? Events { get; set; }
    [Parameter] public string Theme { get; set; } = "fantasy";
    private string ThemeClass => Theme == "steampunk" ? "card-steampunk" : "card-fantasy";

    private string GetEventColor(SessionEvent evt)
    {
        if (evt.CheckResult != null)
        {
            return evt.CheckResult.IsSuccess ? "var(--accent-primary)" : "var(--accent-secondary)";
        }
        if (evt.AttackResult != null)
        {
            return evt.AttackResult.IsHit ? "#8b2020" : "#555";
        }
        return "var(--border-color)";
    }
}
