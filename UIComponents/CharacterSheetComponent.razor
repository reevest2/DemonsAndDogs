@using Models.GameSystems

<div class="card @(ThemeClass) h-100">
    <div class="card-header border-bottom border-secondary">
        <h3 class="heading-@(Theme) m-0">Character Sheet</h3>
    </div>
    <div class="card-body overflow-auto">
        @if (Schema != null)
        {
            @foreach (var sheetSection in Schema.Sections)
            {
                <h4 class="mt-4 border-bottom pb-1 heading-@(Theme)" style="font-size: 1.2rem;">@sheetSection.DisplayName</h4>
                <div class="row">
                    @foreach (var field in sheetSection.Fields)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="p-2" style="background-color: rgba(0,0,0,0.05); border-radius: 4px; border: 1px solid var(--border-color);">
                                <span class="d-block small opacity-75" style="font-family: var(--font-display); text-transform: uppercase;">@field.Label</span>
                                <div class="text-center py-1" style="font-family: var(--font-mono); font-size: 1.2rem; color: var(--accent-primary);">
                                    @(Stats != null && Stats.TryGetValue(field.Key, out var v) ? v : field.DefaultValue)
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="text-center p-4">
                <p>No schema loaded.</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public CharacterSheetSchema? Schema { get; set; }
    [Parameter] public IReadOnlyDictionary<string, int>? Stats { get; set; }
    [Parameter] public string Theme { get; set; } = "fantasy";
    private string ThemeClass => Theme == "steampunk" ? "card-steampunk" : "card-fantasy";
}
