@using Models.GameSystems

<div class="card h-100">
    <div class="card-header glow">Character Sheet</div>
    <div class="card-body overflow-auto">
        @if (Schema != null)
        {
            @foreach (var sheetSection in Schema.Sections)
            {
                <h4 class="mt-4 border-bottom pb-1 glow">@sheetSection.DisplayName</h4>
                <div class="row">
                    @foreach (var field in sheetSection.Fields)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="p-2" style="background-color: rgba(0,0,0,0.03); border-radius: 4px;">
                                <span class="d-block small opacity-75" style="font-family: var(--font-display); text-transform: uppercase;">@field.Label</span>
                                <div class="text-center py-1" style="font-family: var(--font-mono); font-size: 1.2rem; border-bottom: 1px solid var(--accent-primary);">
                                    @field.DefaultValue
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="text-center p-4">
                <p>No schema loaded.</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public CharacterSheetSchema? Schema { get; set; }
}
