@using Models.GameSystems

<div class="card h-100">
    <div class="card-header bg-dark text-white">Character Sheet</div>
    <div class="card-body overflow-auto">
        @if (Schema != null)
        {
            @foreach (var sheetSection in Schema.Sections)
            {
                <h5 class="mt-3 border-bottom pb-1">@sheetSection.DisplayName</h5>
                @foreach (var field in sheetSection.Fields)
                {
                    <div class="row mb-2">
                        <div class="col-6">
                            <span class="text-muted small d-block">@field.Label</span>
                        </div>
                        <div class="col-6">
                            @if (field.Type == "number")
                            {
                                <input type="number" class="form-control form-control-sm text-center font-weight-bold" value="@field.DefaultValue" readonly />
                            }
                            else
                            {
                                <input type="text" class="form-control form-control-sm text-center" value="@field.DefaultValue" readonly />
                            }
                        </div>
                    </div>
                }
            }
        }
        else
        {
            <div class="text-center p-4">
                <p class="text-muted">No schema loaded.</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public CharacterSheetSchema? Schema { get; set; }
}
