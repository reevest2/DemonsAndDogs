@using API.Client.Abstraction
@using Models.Common
@inject ICharacterClient CharacterClient

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="glow">Characters</h2>
        <a href="/characters/new" class="btn-secondary disabled">
            New Character
        </a>
    </div>

    @if (_characters == null)
    {
        <div class="text-center py-5">
            <p class="mt-2 glow">Loading characters...</p>
        </div>
    }
    else if (!_characters.Any())
    {
        <div class="card py-5 text-center">
            <p class="mb-0">No characters found.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @foreach (var character in _characters)
            {
                <div class="col">
                    <div class="card h-100 text-center">
                        <div class="card-body">
                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; border: 2px solid var(--accent-primary); color: var(--accent-primary);">
                                <span style="font-size: 32px;">👤</span>
                            </div>
                            <h4 class="card-title glow">@character.EntityId</h4>
                            <p class="small">@character.RulesetId</p>
                            <div class="mt-3">
                                <a href="/characters/@character.Id" class="btn-primary btn-sm d-block text-center" style="text-decoration: none;">View Sheet</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private IEnumerable<CharacterResource>? _characters;

    protected override async Task OnInitializedAsync()
    {
        _characters = await CharacterClient.GetAllAsync();
    }
}
