@inject UIComponents.Services.ThemeService ThemeService

<nav class="navbar">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <a class="brand" href="/">⚔ Demons & Dogs — Player</a>

        <div class="nav-links d-flex gap-4">
            <div class="nav-item">
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Home</NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="/session/new">New Session</NavLink>
            </div>
        </div>

        <div class="theme-toggle">
            <button class="btn-primary" @onclick="ToggleTheme">
                @(ThemeService.CurrentTheme == "fantasy" ? "⚙ Steampunk" : "📜 Fantasy")
            </button>
        </div>
    </div>
</nav>

@code {
    private void ToggleTheme()
    {
        ThemeService.SetTheme(ThemeService.CurrentTheme == "fantasy" ? "steampunk" : "fantasy");
    }
}
