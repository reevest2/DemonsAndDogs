@page "/DocumentDefinitions"
@using AppConstants
@using Models.Common
@using UIComponents
@inject IApiClient ApiClient
@inject NotificationService NotificationService

<PageTitle>Document Definitions</PageTitle>

<DocumentDefinitionManager Games="@_games"
                           Definitions="@_definitions"
                           OnCreate="OnCreate"
                           OnGameSelected="OnGameSelected" />

@code {
    private IEnumerable<JsonResource> _games = [];
    private IEnumerable<JsonResource> _definitions = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadGames();
    }

    private async Task LoadGames()
    {
        try
        {
            _games = await ApiClient.Get<IEnumerable<JsonResource>>($"api/JsonResource/kind/{ResourceKinds.Game}", default);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error loading games", ex.Message);
        }
    }

    private async Task OnGameSelected(string gameId)
    {
        try
        {
            _definitions = await ApiClient.Get<IEnumerable<JsonResource>>($"api/JsonResource/query?resourceKind={ResourceKinds.DocumentDefinition}&gameId={gameId}", default);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error loading definitions", ex.Message);
        }
    }

    private async Task OnCreate(DocumentDefinitionManager.DefinitionSubmission submission)
    {
        try
        {
            var resource = new DocumentDefinitionResource
            {
                OwnerId = submission.OwnerId,
                GameId = submission.GameId,
                EntityId = submission.Name,
                ResourceKind = ResourceKinds.DocumentDefinition,
                Data = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(submission.JsonContent)
            };
            var result = await ApiClient.Post<JsonResource, JsonResource>("api/JsonResource", resource, default);
            NotificationService.Notify(NotificationSeverity.Success, "Success", $"Definition created: {result.EntityId}");
            await OnGameSelected(submission.GameId);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error creating definition", ex.Message);
        }
    }
}
