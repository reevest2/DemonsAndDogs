@page "/DocumentDefinitions"
@using MediatR
@using Mediator.Mediator.Contracts
@using Models.Resources
@using UIComponents
@inject IMediator Mediator
@inject NotificationService NotificationService

<PageTitle>Document Definitions</PageTitle>

<DocumentDefinitionManager Games="@_games"
                           Definitions="@_definitions"
                           OnCreate="OnCreate"
                           OnGameSelected="OnGameSelected" />

@code {
    private IEnumerable<JsonResource> _games = [];
    private IEnumerable<JsonResource> _definitions = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadGames();
    }

    private async Task LoadGames()
    {
        try
        {
            _games = await Mediator.Send(new GetGamesRequest());
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error loading games", ex.Message);
        }
    }

    private async Task OnGameSelected(string gameId)
    {
        try
        {
            _definitions = await Mediator.Send(new GetDocumentDefinitionsRequest(gameId));
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error loading definitions", ex.Message);
        }
    }

    private async Task OnCreate(DocumentDefinitionManager.DefinitionSubmission submission)
    {
        try
        {
            var result = await Mediator.Send(new CreateDocumentDefinitionRequest(
                submission.OwnerId, submission.GameId, submission.Name, submission.JsonContent));
            NotificationService.Notify(NotificationSeverity.Success, "Success", $"Definition created: {result.EntityId}");
            await OnGameSelected(submission.GameId);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error creating definition", ex.Message);
        }
    }
}
