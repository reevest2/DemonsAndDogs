@page "/Documents"
@using AppConstants
@using Models.Common
@using UIComponents
@inject IApiClient ApiClient
@inject NotificationService NotificationService

<PageTitle>Documents</PageTitle>

<DocumentManager Games="@_games"
                 Campaigns="@_campaigns"
                 Definitions="@_definitions"
                 Documents="@_documents"
                 OnCreate="OnCreate"
                 OnGameSelected="OnGameSelected" />

@code {
    private IEnumerable<JsonResource> _games = [];
    private IEnumerable<JsonResource> _campaigns = [];
    private IEnumerable<JsonResource> _definitions = [];
    private IEnumerable<JsonResource> _documents = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadGames();
    }

    private async Task LoadGames()
    {
        try
        {
            _games = await ApiClient.Get<IEnumerable<JsonResource>>($"api/JsonResource/kind/{ResourceKinds.Game}", default);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error loading games", ex.Message);
        }
    }

    private async Task OnGameSelected(string gameId)
    {
        try
        {
            _campaigns = await ApiClient.Get<IEnumerable<JsonResource>>($"api/JsonResource/query?resourceKind={ResourceKinds.Campaign}&gameId={gameId}", default);
            _definitions = await ApiClient.Get<IEnumerable<JsonResource>>($"api/JsonResource/query?resourceKind={ResourceKinds.DocumentDefinition}&gameId={gameId}", default);
            _documents = await ApiClient.Get<IEnumerable<JsonResource>>($"api/JsonResource/query?resourceKind={ResourceKinds.Document}&gameId={gameId}", default);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error loading data", ex.Message);
        }
    }

    private async Task OnCreate(DocumentManager.DocumentSubmission submission)
    {
        try
        {
            var resource = new DocumentResource
            {
                OwnerId = submission.OwnerId,
                GameId = submission.GameId,
                CampaignId = submission.CampaignId,
                SubjectId = submission.DocumentDefinitionId,
                EntityId = submission.Name,
                ResourceKind = ResourceKinds.Document,
                Data = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(submission.JsonContent)
            };
            var result = await ApiClient.Post<JsonResource, JsonResource>("api/JsonResource", resource, default);
            NotificationService.Notify(NotificationSeverity.Success, "Success", $"Document created: {result.EntityId}");
            await OnGameSelected(submission.GameId);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error creating document", ex.Message);
        }
    }
}
