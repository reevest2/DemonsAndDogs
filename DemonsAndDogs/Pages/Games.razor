@page "/Games"
@using AppConstants
@using Models.Common
@using UIComponents
@inject IApiClient ApiClient
@inject NotificationService NotificationService

<PageTitle>Games</PageTitle>

<GameManager Games="@_games" OnCreate="OnCreate" OnGameSelected="OnGameSelected" />

@code {
    private IEnumerable<JsonResource> _games = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadGames();
    }

    private async Task LoadGames()
    {
        try
        {
            _games = await ApiClient.Get<IEnumerable<JsonResource>>($"api/JsonResource/kind/{ResourceKinds.Game}", default);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error loading games", ex.Message);
        }
    }

    private async Task OnCreate(GameManager.GameSubmission submission)
    {
        try
        {
            var data = new { name = submission.Name, description = submission.Description };
            var resource = new GameResource
            {
                OwnerId = submission.OwnerId,
                EntityId = submission.Name,
                ResourceKind = ResourceKinds.Game,
                Data = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(System.Text.Json.JsonSerializer.Serialize(data))
            };
            var result = await ApiClient.Post<JsonResource, JsonResource>("api/JsonResource", resource, default);
            NotificationService.Notify(NotificationSeverity.Success, "Success", $"Game created: {result.EntityId}");
            await LoadGames();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error creating game", ex.Message);
        }
    }

    private Task OnGameSelected(JsonResource game)
    {
        return Task.CompletedTask;
    }
}
