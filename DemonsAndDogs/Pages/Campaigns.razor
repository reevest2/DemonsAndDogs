@page "/Campaigns"
@using AppConstants
@using Models.Common
@using UIComponents
@inject IApiClient ApiClient
@inject NotificationService NotificationService

<PageTitle>Campaigns</PageTitle>

<CampaignManager Games="@_games"
                 Campaigns="@_campaigns"
                 OnCreate="OnCreate"
                 OnGameSelected="OnGameSelected" />

@code {
    private IEnumerable<JsonResource> _games = [];
    private IEnumerable<JsonResource> _campaigns = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadGames();
    }

    private async Task LoadGames()
    {
        try
        {
            _games = await ApiClient.Get<IEnumerable<JsonResource>>($"api/JsonResource/kind/{ResourceKinds.Game}", default);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error loading games", ex.Message);
        }
    }

    private async Task OnGameSelected(string gameId)
    {
        try
        {
            _campaigns = await ApiClient.Get<IEnumerable<JsonResource>>($"api/JsonResource/query?resourceKind={ResourceKinds.Campaign}&gameId={gameId}", default);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error loading campaigns", ex.Message);
        }
    }

    private async Task OnCreate(CampaignManager.CampaignSubmission submission)
    {
        try
        {
            var data = new { name = submission.Name, description = submission.Description };
            var resource = new CampaignResource
            {
                OwnerId = submission.OwnerId,
                GameId = submission.GameId,
                EntityId = submission.Name,
                ResourceKind = ResourceKinds.Campaign,
                Data = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(System.Text.Json.JsonSerializer.Serialize(data))
            };
            var result = await ApiClient.Post<JsonResource, JsonResource>("api/JsonResource", resource, default);
            NotificationService.Notify(NotificationSeverity.Success, "Success", $"Campaign created: {result.EntityId}");
            await OnGameSelected(submission.GameId);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error creating campaign", ex.Message);
        }
    }
}
