@using API.Client.Abstraction
@using Models.Common
@inject ICharacterClient CharacterClient

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Characters</h2>
        <a href="/characters/new" class="btn btn-outline-primary disabled">
            <i class="oi oi-plus mr-1"></i>New Character
        </a>
    </div>

    @if (_characters == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading characters...</p>
        </div>
    }
    else if (!_characters.Any())
    {
        <div class="alert alert-info py-5 text-center shadow-sm">
            <i class="oi oi-info display-4 mb-3"></i>
            <p class="mb-0">No characters found.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @foreach (var character in _characters)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 text-center">
                        <div class="card-body">
                            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                                <i class="oi oi-person text-primary" style="font-size: 32px;"></i>
                            </div>
                            <h5 class="card-title font-weight-bold">@character.EntityId</h5>
                            <p class="text-muted small">@character.RulesetId</p>
                            <div class="mt-3">
                                <a href="/characters/@character.Id" class="btn btn-primary btn-sm px-4">View Sheet</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private IEnumerable<JsonResource>? _characters;

    protected override async Task OnInitializedAsync()
    {
        _characters = await CharacterClient.GetAllAsync();
    }
}
