@inject UIComponents.Services.ThemeService ThemeService
@inject UIComponents.Services.AppLinksService AppLinks

<nav class="navbar">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <a class="brand" href="/">⚔ Demons & Dogs — Builder</a>

        <div class="nav-links d-flex gap-4 align-items-center">
            <div class="nav-item">
                <NavLink class="nav-link" href="/campaigns" Match="NavLinkMatch.All">Campaigns</NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="/characters">Characters</NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="/systems">Game Systems</NavLink>
            </div>
            <div class="nav-item">
                <a href="@AppLinks.PlayerBaseUrl" target="_blank" rel="noopener"
                   class="btn-secondary" style="font-size: 0.85rem; padding: 0.3rem 0.75rem; text-decoration: none;">
                    Play Test &#x2197;
                </a>
            </div>
        </div>

        <div class="theme-toggle">
            <button class="btn-primary" @onclick="ToggleTheme">
                @(ThemeService.CurrentTheme == "fantasy" ? "⚙ Steampunk" : "📜 Fantasy")
            </button>
        </div>
    </div>
</nav>

@code {
    private void ToggleTheme()
    {
        ThemeService.SetTheme(ThemeService.CurrentTheme == "fantasy" ? "steampunk" : "fantasy");
    }
}
